# Public site URL (no trailing slash) — used for canonical URLs and absolute Open Graph images
# VITE_SITE_URL=https://www.vinoveil.com

# Shopify commerce (all VITE_* are exposed to the browser — never put secrets here)
# VITE_SHOPIFY_STORE_URL=your-store.myshopify.com
# VITE_SHOPIFY_PRODUCT_HANDLE=your-product-handle
# Optional: full product URL instead of store + handle
# VITE_SHOPIFY_PRODUCT_URL=https://your-store.myshopify.com/products/your-product-handle
# Optional: Buy Button embed URL or checkout permalink (takes priority over product URL for CTAs)
# VITE_SHOPIFY_BUY_BUTTON_URL=
# Set to "true" to enable purchase CTAs that link out to Shopify
# VITE_ENABLE_SHOPIFY_CHECKOUT=false

# Optional: waitlist mailto — if unset, waitlist CTAs go to /contact#waitlist
# VITE_WAITLIST_EMAIL=hello@vinoveil.com
